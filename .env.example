# Supabase 연결 정보 (https://supabase.com 프로젝트 → Settings → API)
# 이 파일을 .env.local 로 복사한 뒤 실제 값을 채우세요.

# 프로젝트 URL (예: https://xxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# anon (public) key — 브라우저/서버 공용, RLS 적용됨
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service role key — 서버 전용, RLS 우회. 절대 클라이언트에 노출 금지
SUPABASE_SERVICE_ROLE_KEY=
